# Server Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=True

# Database Configuration
# For MySQL: mysql+pymysql://user:password@host:port/database_name
# For SQLite (default development): sqlite:///./onboardgenius.db
DATABASE_URL=sqlite:///./onboardgenius.db

# JWT Configuration
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=supersecretkeyonboardgenius1234567890abcdef
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# File Upload Configuration
UPLOAD_DIR=./uploads

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
